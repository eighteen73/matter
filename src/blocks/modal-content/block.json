{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "matter/modal-content",
	"version": "0.1.0",
	"title": "Modal Content",
	"category": "widgets",
	"description": "The content displayed inside a modal.",
	"parent": [ "matter/modal" ],
	"attributes": {
		"backdropColor": {
			"type": "string",
			"default": ""
		},
		"backdropOpacity": {
			"type": "number",
			"default": 50
		},
		"backdropBlur": {
			"type": "number",
			"default": 0
		},
		"width": {
			"type": "string",
			"default": ""
		},
		"height": {
			"type": "string",
			"default": ""
		}
	},
	"supports": {
		"color": {
			"text": true,
			"background": true,
			"gradients": false
		},
		"html": false,
		"lock": false,
		"reusable": false,
		"spacing": {
			"margin": true,
			"padding": true,
			"blockGap": true,
			"__experimentalDefaultControls": {
				"blockGap": false,
				"margin": false,
				"padding": true
			}
		},
		"__experimentalBorder": {
			"color": true,
			"radius": true,
			"style": true,
			"width": true,
			"__experimentalDefaultControls": {
				"color": false,
				"radius": false,
				"style": false,
				"width": false
			}
		}
	},
	"usesContext": [ "matter/modal-id", "matter/modal-is-open" ],
	"textdomain": "matter",
	"editorScript": "file:./index.js",
	"editorStyle": "file:./index.css",
	"style": "file:./style-index.css",
	"render": "file:./render.php"
}
