{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "eighteen73/navigation",
	"version": "0.1.0",
	"title": "Navigation",
	"category": "theme",
	"description": "Select and render an existing Navigation menu as a simplified, read-only block.",
	"attributes": {
		"ref": {
			"type": "number",
			"default": 0
		},
		"type": {
			"type": "string",
			"default": "simple",
			"enum": [ "simple", "accordion", "drill-down" ]
		}
	},
	"supports": {
		"html": false,
		"anchor": true,
		"layout": {
			"default": {
				"type": "flex"
			},
			"allowSwitching": false,
			"allowInheriting": false,
			"allowVerticalAlignment": false,
			"allowSizingOnChildren": true
		},
		"color": {
			"text": true,
			"background": true,
			"gradients": false,
			"link": false
		},
		"spacing": {
			"blockGap": true,
			"margin": true,
			"padding": true,
			"__experimentalDefaultControls": {
				"blockGap": true,
				"margin": false,
				"padding": false
			}
		}
	},
	"textdomain": "eighteen73-blocks",
	"editorScript": "file:./index.js",
	"style": "file:./style-index.css",
	"editorStyle": "file:./index.css",
	"render": "file:./render.php"
}
