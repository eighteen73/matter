{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "eighteen73-blocks/carousel-progress",
	"version": "0.1.0",
	"title": "Carousel Progress",
	"category": "design",
	"icon": "minus",
	"description": "Carousel Progress",
	"ancestor": [
		"eighteen73-blocks/carousel"
	],
	"attributes": {
		"indicateCurrentPosition": {
			"type": "boolean",
			"default": false
		},
		"barColor": {
			"type": "string"
		},
		"customBarColor": {
			"type": "string"
		}
	},
	"supports": {
		"color": {
			"text": false,
			"background": true,
			"gradients": false,
			"link": false
		},
		"__experimentalBorder": {
			"radius": true
		}
	},
	"textdomain": "eighteen73-blocks",
	"editorScript": "file:./index.js",
	"style": "file:./style-index.css",
	"render": "file:./render.php"
}
