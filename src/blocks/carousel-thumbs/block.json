{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "matter/carousel-thumbs",
	"version": "0.1.0",
	"title": "Thumbs",
	"category": "design",
	"icon": "grid-view",
	"description": "Displays thumbnail blocks to navigate between carousel slides.",
