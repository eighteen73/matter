{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "matter/tab-panel",
  "version": "0.1.0",
  "title": "Tab Panel",
  "description": "Content for a tab in a tabbed interface.",
  "category": "widgets",
  "textdomain": "matter",
  "attributes": {
    "inQueryLoop": {
      "type": "boolean",
      "default": false
    },
    "label": {
      "type": "string"
    }
  },
  "parent": [
    "matter/tab-panels",
    "core/post-template"
  ],
  "ancestor": [
    "matter/tabs"
  ],
  "usesContext": [
    "matter/tabs-activeTabIndex",
    "matter/tabs-editorActiveTabIndex",
    "matter/tabs-id",
    "matter/tabs-list",
    "matter/tabs-isQueryMode",
    "postId",
    "postType",
    "queryId"
  ],
  "supports": {
    "anchor": true,
    "html": false,
    "reusable": false,
    "color": {
      "background": true,
      "text": true
    },
    "spacing": {
      "blockGap": true,
      "padding": true,
      "margin": false
    },
    "layout": {
      "default": {
        "type": "default"
      },
      "allowSwitching": false
    },
    "__experimentalBorder": {
      "radius": true
    },
    "renaming": true,
    "visibility": false
  },
  "editorScript": "file:./index.js",
  "style": "file:./style-index.css",
  "render": "file:./render.php"
}